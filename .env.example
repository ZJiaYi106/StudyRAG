# ============================================================
# StudyRAG 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值
# ============================================================

# --- LLM 配置（示例：DeepSeek）---
# 可换成任何 OpenAI API 兼容服务
LLM_API_KEY=sk-你的Key
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- Embedding 配置（示例：智谱 GLM）---
# 注意：LLM 和 Embedding 可以使用不同服务商
EMBEDDING_API_KEY=你的Key
EMBEDDING_API_BASE=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-2

# --- Chroma 向量数据库 ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=studyarag_docs

# --- 应用配置 ---
# 文档上传目录（容器内路径，一般不需要修改）
UPLOAD_DIR=/app/data/uploads
# 切分参数
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# 检索参数
TOP_K=4
# 相关性阈值：低于此分数的检索结果将被丢弃
SIMILARITY_THRESHOLD=0.5

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
